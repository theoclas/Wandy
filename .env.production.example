# Copia este archivo a .env.production en la VPS y completa los valores.
# Nunca subas .env.production al repositorio.

# Postgres
POSTGRES_USER=wandy
# Puede incluir símbolos; se codifican automáticamente en la URL
POSTGRES_PASSWORD=cambia-esta-clave-fuerte
POSTGRES_DB=wandy

# API
JWT_SECRET=cambia-este-secreto-jwt-largo-y-aleatorio
JWT_EXPIRES_IN=8h
# Orígenes permitidos (coma-separados). Incluye el puerto del front.
# Ejemplo: http://TU_IP:8085
CORS_ORIGIN=http://TU_IP:8085
# true solo la primera vez para crear admin/profesional de prueba
RUN_SEED=true

# Puertos públicos (cámbialos si chocan con otros proyectos en la VPS)
# Front (Nginx): app completa → http://TU_IP:8085
HTTP_PORT=8085
# API directa (opcional) → http://TU_IP:3085/api
API_PORT=3085
